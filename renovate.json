{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Auto-merge low-risk updates (pin/digest/patch/minor) once required checks pass — keeps the queue self-clearing.",
      "matchUpdateTypes": ["pin", "pinDigest", "digest", "patch", "minor"],
      "automerge": true,
      "automergeStrategy": "squash",
      "platformAutomerge": true
    },
    {
      "description": "Group all GitHub Actions bumps into a single PR.",
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    },
    {
      "description": "Major bumps are breaking — never auto-merge; leave for review.",
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ]
}
