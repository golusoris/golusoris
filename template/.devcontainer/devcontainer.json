{
  "name": "golusoris app",
  "image": "mcr.microsoft.com/devcontainers/go:1-1.24-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/node:1": { "version": "lts" }
  },
  "postCreateCommand": "go install github.com/air-verse/air@latest && go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest && go install golang.org/x/vuln/cmd/govulncheck@latest && go install github.com/sqlc-dev/sqlc/cmd/sqlc@latest",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "ms-azuretools.vscode-docker",
        "github.copilot",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "go.toolsManagement.checkForUpdates": "local",
        "go.useLanguageServer": true,
        "go.lintTool": "golangci-lint",
        "go.lintOnSave": "workspace",
        "editor.formatOnSave": true
      }
    }
  },
  "forwardPorts": [8080, 5432, 6379, 4222],
  "portsAttributes": {
    "8080": { "label": "App" },
    "5432": { "label": "Postgres" },
    "6379": { "label": "Redis" },
    "4222": { "label": "NATS" }
  }
}
